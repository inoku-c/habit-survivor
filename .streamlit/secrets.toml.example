# Streamlit Community Cloud の「Secrets」に設定する内容
# ダッシュボード → アプリ設定 → Secrets に以下をペースト

# ── アクセスコード（カンマ区切り）──────────────────
# 購入者に発行するコードを追加してください
access_codes = "HEALTH2024PRO,DEMO_PRO,YOUR_CODE_HERE"

# ── Stripe 決済リンク ──────────────────────────────
# Stripe ダッシュボード → Payment Links で作成したURLを設定
stripe_payment_link = "https://buy.stripe.com/your_actual_link"
